{
    "server": {
        "listenerAddress": "0.0.0.0",
        "listenerPort": 5020,
        "protocol": "TCP",
        "logging": {
            "format": "%(asctime)-15s %(threadName)-15s  %(levelname)-8s %(module)-15s:%(lineno)-8s %(message)s",
            "logLevel": "INFO"
        },
        "tlsParams": {
            "description": "path to certificate and private key to enable tls",
            "privateKey": null,
            "certificate": null
        }
    },
    "registers": {
        "description": "initial values for the register types",
        "zeroMode": true,
        "initializeUndefinedRegisters": false,
        "coils": {
            "100": false,
            "101": true
        },
        "discreteInput": {
            "10100": true,
            "10101": false
        },
        "inputRegister": {
            "30100": "0x0101",
            "30101": "0x0011",
            "30102": "0x0111"
        },
        "holdingRegister": {
            "40100": "0x0111",
            "40101": "0x0011",
            "40102": "0x0100",
            "40103": "0xFFFF",
            "40104": "0x0000",
            "40105": "0xDEAD",
            "40106": "0xBEEF",
            "40110": "0x1010",
            "40120": "0xABCD",
            "40121": "0xEF01",
            "40122": "0x2345",
            "40123": "0x6789"
        }
    }
}